# LLM Provider configuration: 'huggingface', 'anthropic', or 'nvidia'
MODEL_PROVIDER=huggingface

# Model name:
# e.g., 'google/gemma-2-9b-it' (Hugging Face - default)
# e.g., 'claude-haiku-4-5-20251001' (Anthropic)
# e.g., 'meta-llama/llama-3.1-8b-instruct' (NVIDIA NIM)
MODEL_NAME=google/gemma-2-9b-it

# API Credentials (only set the ones you use)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
HF_API_KEY=your_huggingface_token_here
NVIDIA_API_KEY=your_nvidia_nim_key_here
